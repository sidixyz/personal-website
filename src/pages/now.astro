---
import Layout from "@layouts/Layout.astro";
import "../styles/global.css";

const roles = [
  { org: "The Knowledge Society (TKS)", role: "Velocity Member", detail: "Top 7% globally", year: "2024–Present" },
  { org: "Mayfield DECA", role: "VP of Training", detail: "Youngest ever", year: "2024–Present" },
  { org: "TEDx Peel District School Board", role: "Speaker", detail: "1 of 12 from 250+ applicants", year: "Apr 2026" },
  { org: "FPLC National Advisory Council", role: "Member", detail: "", year: "2025" },
  { org: "Forum for Young Canadians", role: "Delegate", detail: "Ottawa", year: "2026" },
  { org: "Yale Young Global Scholars", role: "Scholar", detail: "", year: "2025" },
  { org: "Camp Rising Sun", role: "Finalist", detail: "Full-scholarship leadership program, NY", year: "2026" },
];

const stats = [
  { value: "97.75%", label: "Academic average" },
  { value: "Top 7%", label: "TKS Velocity globally" },
  { value: "Top 19", label: "Globally, TKS × Lovable" },
  { value: "99th %ile", label: "Mensa Canada" },
  { value: "2,400", label: "Students at my conference" },
  { value: "250+", label: "TEDx applicants I beat" },
];
---

<Layout>
  <section class="py-16">
    <h1 class="text-2xl font-semibold text-[#0e141b] mb-2">Now</h1>
    <p class="text-sm text-gray-500 mb-12">What I'm part of and what I've done.</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-px border border-gray-100 rounded-lg overflow-hidden mb-16">
      {stats.map((s) => (
        <div class="bg-white p-5 border border-gray-100">
          <div class="text-xl font-semibold text-[#0e141b] mb-1">{s.value}</div>
          <div class="text-xs text-gray-500">{s.label}</div>
        </div>
      ))}
    </div>

    <h2 class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-6">Roles & Programs</h2>
    <div class="divide-y divide-gray-100">
      {roles.map((r) => (
        <div class="py-4 flex justify-between items-start gap-4">
          <div>
            <p class="text-sm font-medium text-[#0e141b]">{r.role}</p>
            <p class="text-sm text-gray-500">{r.org}{r.detail ? ` — ${r.detail}` : ""}</p>
          </div>
          <span class="text-xs text-gray-400 flex-shrink-0">{r.year}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
