---
import Layout from "@layouts/Layout.astro";
import "../styles/global.css";

const projects = [
  {
    name: "Zenn — Stress-Detection Bracelet",
    year: "2025",
    tag: "Neurotechnology",
    description:
      "Smart wearable using haptic vibrations and transcutaneous median nerve stimulation at acupressure points PC5/PC6 to automatically activate the parasympathetic nervous system. Built at TKS Hackathon.",
  },
  {
    name: "TKS × Lovable Consulting Challenge",
    year: "2026",
    tag: "Consulting",
    description:
      "Top 5 in Toronto, Top 19 globally out of hundreds of international TKS teams. Built a 25-slide deck on organic customer acquisition via Generative Engine Optimization — reviewed directly by Lovable executives.",
  },
  {
    name: "Canadian National Leadership Conference",
    year: "2025",
    tag: "Leadership",
    description:
      "Organized Canada's largest student-led business conference — 2,400 high school students in downtown Toronto.",
  },
  {
    name: "TEDx Talk — Peel District School Board",
    year: "2026",
    tag: "Speaking",
    description:
      "One of 12 speakers selected from 250+ applicants across the Peel Region. Cold-messaged the organizer two months after the deadline. She said yes.",
  },
  {
    name: "NeuroSync",
    year: "2025",
    tag: "Neurotechnology",
    description:
      "BCI research project exploring real-time neural signal processing. Validated with professors and engineers in the neurotechnology space.",
  },
];
---

<Layout>
  <section class="py-16">
    <h1 class="text-2xl font-semibold text-[#0e141b] mb-2">Projects</h1>
    <p class="text-sm text-gray-500 mb-12">Things I've built, led, or shipped.</p>

    <div class="divide-y divide-gray-100">
      {projects.map((p) => (
        <div class="py-6 flex justify-between items-start gap-6">
          <div>
            <h2 class="text-sm font-medium text-[#0e141b] mb-1">{p.name}</h2>
            <p class="text-sm text-gray-500 leading-relaxed max-w-lg">{p.description}</p>
          </div>
          <div class="flex flex-col items-end gap-2 flex-shrink-0">
            <span class="text-xs text-gray-400">{p.year}</span>
            <span class="text-xs border border-gray-200 rounded-full px-2 py-0.5 text-gray-400">{p.tag}</span>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
