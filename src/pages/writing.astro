---
import Layout from "@layouts/Layout.astro";
import "../styles/global.css";

const issues = [
  {
    title: "February 2026 — Grit",
    date: "Feb 2026",
    description:
      "On grit, DECA Provincials, the TKS × Lovable challenge, and getting selected for TEDx after the deadline had already closed.",
  },
];
---

<Layout>
  <section class="py-16">
    <h1 class="text-2xl font-semibold text-[#0e141b] mb-2">Writing</h1>
    <p class="text-sm text-gray-500 mb-3">
      I write <em>inSIDIous</em> — a monthly newsletter where I slow down to reflect while I keep building.
    </p>
    
      href="mailto:sidharth.mohal@gmail.com?subject=Subscribe to inSIDIous"
      class="inline-block text-xs border border-gray-200 rounded-full px-3 py-1.5 text-gray-500 hover:text-[#0e141b] hover:border-gray-400 transition-colors mb-12"
    >
      Subscribe →
    </a>

    <div class="divide-y divide-gray-100">
      {issues.map((issue) => (
        <div class="py-6">
          <div class="flex justify-between items-start mb-2">
            <h2 class="text-sm font-medium text-[#0e141b]">{issue.title}</h2>
            <span class="text-xs text-gray-400">{issue.date}</span>
          </div>
          <p class="text-sm text-gray-500 leading-relaxed">{issue.description}</p>
        </div>
      ))}
    </div>
  </section>
</Layout>
