---
const { navLinks } = Astro.props;
const currentPath = Astro.url?.pathname ?? "/";
---

<header class="sticky top-0 z-50 mx-auto flex max-w-3xl animate-slide-in justify-between bg-white px-5 py-6 border-b border-gray-100">
  <a href="/" class="font-medium text-[#0e141b] text-sm tracking-tight">
    Sidi Mohal
  </a>
  <nav id="main-menu">
    <ul class="flex gap-1">
      {navLinks.map((link: { text: string; href: string }) => (
        <li>
          
            class={`block px-3 py-1.5 text-sm rounded-md transition-all duration-200 ${currentPath === link.href ? "text-[#0e141b] font-medium" : "text-gray-500 hover:text-[#0e141b]"}`}
            href={link.href}
          >
            {link.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  header {
    animation-timeline: scroll();
    animation-range: 0 650px;
  }
</style>
